void setup() {
  // Hier geef ik aan welke pinnen ik gebruik voor de 8 LEDS.
  // Elke pin wordt een OUTPUT
  pinMode(13, OUTPUT);
  pinMode(12, OUTPUT);
  pinMode(11, OUTPUT);
  pinMode(10, OUTPUT);
  pinMode(9, OUTPUT);
  pinMode(8, OUTPUT);
  pinMode(7, OUTPUT);
  pinMode(6, OUTPUT);
}

void loop() {
  // De LED's gaan eerst een voor een heen.
  // Elke LED gaat kort aan, daarna weer uit, en dan gaat de volgende LED aan.

  digitalWrite(13, HIGH);  // LED op pin 13 gaat aan
  delay(200);              // Wacht 200 milliseconden
  digitalWrite(13, LOW);   // LED op pin 13 gaat weer uit

  digitalWrite(12, HIGH);  // LED op pin 12 gaat aan
  delay(200);
  digitalWrite(12, LOW);

  digitalWrite(11, HIGH);  // LED op pin 11 gaat aan
  delay(200);
  digitalWrite(11, LOW);

  digitalWrite(10, HIGH);  // LED op pin 10 gaat aan
  delay(200);
  digitalWrite(10, LOW);

  digitalWrite(9, HIGH);   // LED op pin 9 gaat aan
  delay(200);
  digitalWrite(9, LOW);

  digitalWrite(8, HIGH);   // LED op pin 8 gaat aan
  delay(200);
  digitalWrite(8, LOW);

  digitalWrite(7, HIGH);   // LED op pin 7 gaat aan
  delay(200);
  digitalWrite(7, LOW);

  digitalWrite(6, HIGH);   // LED op pin 6 gaat aan
  delay(200);
  digitalWrite(6, LOW);

  // Nu gaan de LEDS weer terug de andere kant op.
  // Pin 6 hoeft niet opnieuw meteen aan, want die was net al geweest.

  digitalWrite(7, HIGH);   // LED op pin 7 gaat aan
  delay(200);
  digitalWrite(7, LOW);

  digitalWrite(8, HIGH);   // LED op pin 8 gaat aan
  delay(200);
  digitalWrite(8, LOW);

  digitalWrite(9, HIGH);   // LED op pin 9 gaat aan
  delay(200);
  digitalWrite(9, LOW);

  digitalWrite(10, HIGH);  // LED op pin 10 gaat aan
  delay(200);
  digitalWrite(10, LOW);

  digitalWrite(11, HIGH);  // LED op pin 11 gaat aan
  delay(200);
  digitalWrite(11, LOW);

  digitalWrite(12, HIGH);  // LED op pin 12 gaat aan
  delay(200);
  digitalWrite(12, LOW);

  // Daarna begint de loop automatisch opnieuw bij pin 13.
}



