int teller = 0;
int knopStatus = 0;
int vorigeKnopStatus = 0;

void setup() {
  // Pinnen voor de twee ledjes
  pinMode(5, OUTPUT);
  pinMode(11, OUTPUT);

  // Pin voor de drukknop
  pinMode(8, INPUT);
}

void loop() {
  // Leest of de knop is ingedrukt
  knopStatus = digitalRead(8);

  // Als de knop net is ingedrukt, tel ik er 1 bij op
  if (knopStatus == HIGH && vorigeKnopStatus == LOW) {
    teller++;
    delay(50); // kleine pauze tegen contactdender
  }

  // Bij een even getal brandt led 1
  if (teller % 2 == 0) {
    digitalWrite(5, HIGH);
    digitalWrite(11, LOW);
  } 
  // Bij een oneven getal brandt led 2
  else {
    digitalWrite(5, LOW);
    digitalWrite(11, HIGH);
  }

  // Onthoudt de vorige knopstatus
  vorigeKnopStatus = knopStatus;
}

